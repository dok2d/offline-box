<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Offline Box</title>
<style>
:root {
  --bg: #0f1117;
  --card: #1a1d2e;
  --card-hover: #222640;
  --border: #2a2e3f;
  --text: #e0e4ef;
  --text-dim: #8890a4;
  --accent: #6c8aff;
  --green: #34d399;
  --red: #f87171;
  --yellow: #fbbf24;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding: 0;
}
.header {
  text-align: center;
  padding: 48px 20px 32px;
}
.header h1 {
  font-size: 2.2rem;
  font-weight: 700;
  letter-spacing: -0.5px;
  color: #fff;
}
.header p {
  color: var(--text-dim);
  margin-top: 8px;
  font-size: 0.95rem;
}
.status-bar {
  display: flex;
  justify-content: center;
  gap: 24px;
  padding: 0 20px 32px;
  flex-wrap: wrap;
}
.status-bar .stat {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.85rem;
  color: var(--text-dim);
}
.stat .dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}
.stat .dot.green { background: var(--green); }
.stat .dot.red { background: var(--red); }
.stat .dot.yellow { background: var(--yellow); }
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px 48px;
}
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-decoration: none;
  color: inherit;
  transition: background 0.15s, border-color 0.15s;
  position: relative;
}
.card:hover {
  background: var(--card-hover);
  border-color: var(--accent);
}
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.card-top h2 {
  font-size: 1.05rem;
  font-weight: 600;
  color: #fff;
}
.badge {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 3px 8px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  gap: 4px;
}
.badge .dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}
.badge.online { background: rgba(52,211,153,0.12); color: var(--green); }
.badge.online .dot { background: var(--green); }
.badge.offline { background: rgba(248,113,113,0.12); color: var(--red); }
.badge.offline .dot { background: var(--red); }
.badge.checking { background: rgba(251,191,36,0.12); color: var(--yellow); }
.badge.checking .dot { background: var(--yellow); }
.card-desc {
  font-size: 0.85rem;
  color: var(--text-dim);
  line-height: 1.4;
}
.card-icon {
  font-size: 1.5rem;
  margin-bottom: 4px;
}
.footer {
  text-align: center;
  padding: 0 20px 32px;
  font-size: 0.8rem;
  color: var(--text-dim);
}
@media (max-width: 600px) {
  .header { padding: 32px 16px 24px; }
  .header h1 { font-size: 1.6rem; }
  .grid { grid-template-columns: 1fr; padding: 0 16px 32px; }
}
</style>
</head>
<body>

<div class="header">
  <h1>Offline Box</h1>
  <p>{{ server_name }}</p>
</div>

<div class="status-bar">
  <div class="stat"><span class="dot green"></span> <span id="count-online">0</span> online</div>
  <div class="stat"><span class="dot red"></span> <span id="count-offline">0</span> offline</div>
  <div class="stat" style="color:var(--text-dim)">Updated: <span id="last-check">--:--</span></div>
</div>

<div class="grid" id="services"></div>

<div class="footer">Auto-refresh every 30s</div>

<script>
var services = [
{% for svc_id, svc in offlinebox_services.items() %}
{% if svc.enabled | bool %}
  {id:"{{ svc_id }}", name:"{{ svc.dashboard.name }}", desc:"{{ svc.dashboard.desc }}", url:"{{ svc.dashboard.url }}", icon:"{{ svc.dashboard.icon }}"},
{% endif %}
{% endfor %}
];

var grid = document.getElementById("services");

function render() {
  grid.innerHTML = "";
  services.forEach(function(s) {
    var a = document.createElement("a");
    a.href = s.url;
    a.className = "card";
    a.id = "card-" + s.id;
    var st = s.status || "checking";
    var label = st === "online" ? "Online" : st === "offline" ? "Offline" : "Checking";
    a.innerHTML =
      '<div class="card-icon">' + s.icon + '</div>' +
      '<div class="card-top"><h2>' + s.name + '</h2>' +
      '<span class="badge ' + st + '"><span class="dot"></span>' + label + '</span></div>' +
      '<div class="card-desc">' + s.desc + '</div>';
    grid.appendChild(a);
  });
}

function updateCounts() {
  var on = 0, off = 0;
  services.forEach(function(s) {
    if (s.status === "online") on++;
    else if (s.status === "offline") off++;
  });
  document.getElementById("count-online").textContent = on;
  document.getElementById("count-offline").textContent = off;
  var now = new Date();
  document.getElementById("last-check").textContent =
    String(now.getHours()).padStart(2,"0") + ":" + String(now.getMinutes()).padStart(2,"0");
}

function checkHealth() {
  services.forEach(function(s) {
    var controller = new AbortController();
    var timer = setTimeout(function() { controller.abort(); }, 5000);
    fetch(s.url, {method:"HEAD", signal:controller.signal, redirect:"follow"})
      .then(function(r) {
        clearTimeout(timer);
        s.status = (r.ok || r.status === 302 || r.status === 301) ? "online" : "offline";
      })
      .catch(function() {
        clearTimeout(timer);
        s.status = "offline";
      })
      .finally(function() {
        render();
        updateCounts();
      });
  });
}

render();
checkHealth();
setInterval(checkHealth, 30000);
</script>
</body>
</html>
