FROM {{ container_base_image }}
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    libxml2 libxslt1.1 libmagic1 && \
    rm -rf /var/lib/apt/lists/*
RUN useradd -r -u 10001 -m calibre && \
    mkdir -p /app /books /config && \
    chown -R calibre:calibre /app /books /config
USER calibre
RUN python3 -m venv /app/venv && \
    /app/venv/bin/pip install --no-cache-dir calibreweb
EXPOSE {{ calibre_web_port }}
ENTRYPOINT ["/app/venv/bin/cps", "-p", "/config/app.db", "-g", "/config/gdrive.db"]
