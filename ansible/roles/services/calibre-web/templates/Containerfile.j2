FROM {{ container_base_image }}
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    libxml2 libxslt1.1 libmagic1 curl && \
    rm -rf /var/lib/apt/lists/*
RUN useradd -r -u 10001 -m calibre && \
    mkdir -p /app /books /config && \
    chown -R calibre:calibre /app /books /config
USER calibre
{% if offline_mode | default(false) %}
COPY pip-packages/ /tmp/pip-packages/
RUN python3 -m venv /app/venv && \
    /app/venv/bin/pip install --no-cache-dir --no-index --find-links /tmp/pip-packages calibreweb=={{ calibre_web_version }} && \
    rm -rf /tmp/pip-packages
{% else %}
RUN python3 -m venv /app/venv && \
    /app/venv/bin/pip install --no-cache-dir calibreweb=={{ calibre_web_version }}
{% endif %}
EXPOSE {{ calibre_web_port }}
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD curl -fs http://localhost:8008/ || exit 1
ENTRYPOINT ["/app/venv/bin/cps", "-p", "/config/app.db", "-g", "/config/gdrive.db"]
