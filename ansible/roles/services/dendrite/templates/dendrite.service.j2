[Unit]
Description=Dendrite Matrix homeserver (podman)
After=default.target

[Service]
Environment="XDG_RUNTIME_DIR=/run/user/{{ svc_uid }}"
ExecStartPre=-/usr/bin/podman rm -f dendrite
ExecStart=/usr/bin/podman run \
  --name dendrite \
  --replace \
  --rm \
  --cap-drop=ALL \
  --security-opt=no-new-privileges \
  -p {{ listen_addr }}:{{ dendrite_port }}:{{ dendrite_port }} \
  --log-driver=k8s-file \
  --log-opt=path={{ container_log_dir }}/dendrite/dendrite.log \
  -v {{ dendrite_data_dir }}:/data:rw \
  -v {{ dendrite_config_dir }}:/etc/dendrite:ro \
  {{ dendrite_image_full }}
ExecStop=/usr/bin/podman stop dendrite
MemoryMax=1G
CPUQuota=200%
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
