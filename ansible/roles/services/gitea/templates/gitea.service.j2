[Unit]
Description=Gitea git hosting (podman)
After=default.target

[Service]
Environment="XDG_RUNTIME_DIR=/run/user/{{ svc_uid }}"
ExecStartPre=-/usr/bin/podman rm -f gitea
ExecStart=/usr/bin/podman run \
  --name gitea \
  --replace \
  --rm \
  --cap-drop=ALL \
  --security-opt=no-new-privileges \
  -p {{ listen_addr }}:{{ gitea_port }}:{{ gitea_port }} \
  -p {{ gitea_ssh_port }}:2222 \
  --log-driver=k8s-file \
  --log-opt=path={{ container_log_dir }}/gitea/gitea.log \
  -v {{ gitea_data_dir }}:/data:rw \
  -v {{ gitea_config_dir }}:/etc/gitea:rw \
  {{ gitea_image_full }}
ExecStop=/usr/bin/podman stop gitea
MemoryMax=1G
CPUQuota=200%
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
