FROM {{ container_base_image }}
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl gnupg ca-certificates && \
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://repo.jellyfin.org/jellyfin_team.gpg.key | \
      gpg --dearmor -o /etc/apt/keyrings/jellyfin.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/jellyfin.gpg] https://repo.jellyfin.org/deb bookworm main" \
      > /etc/apt/sources.list.d/jellyfin.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends jellyfin-server jellyfin-web jellyfin-ffmpeg6 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*
RUN useradd -r -u 10001 -m jellyfin && \
    mkdir -p /config /cache /media && \
    chown -R jellyfin:jellyfin /config /cache /media
USER jellyfin
EXPOSE {{ jellyfin_port }}
ENTRYPOINT ["/usr/bin/jellyfin", "--service", \
    "--datadir", "/config", \
    "--cachedir", "/cache", \
    "--webdir", "/usr/share/jellyfin/web", \
    "--baseurl", "/jellyfin"]
