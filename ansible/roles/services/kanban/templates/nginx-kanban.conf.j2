# Kanban - task board
location /kanban/ {
    proxy_pass http://{{ listen_addr }}:{{ kanban_port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    include /etc/nginx/snippets/security-headers.conf;
    limit_req zone=general burst=20 nodelay;
    client_max_body_size {{ kanban_upload_max_size }};

    # WebSocket for real-time notifications
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 3600;

    # Kanban SPA generates absolute paths; rewrite for /kanban/ sub-path
    sub_filter_once off;
    sub_filter_types text/html application/javascript text/javascript;
    sub_filter '"/api/' '"/kanban/api/';
    sub_filter '"/static/' '"/kanban/static/';
    sub_filter '"/images/' '"/kanban/images/';
    sub_filter '"/files/' '"/kanban/files/';
    sub_filter 'href="/"' 'href="/kanban/"';
    sub_filter 'action="/"' 'action="/kanban/"';
    sub_filter "fetch('/api/" "fetch('/kanban/api/";
    sub_filter "fetch(\"/api/" "fetch(\"/kanban/api/";
    proxy_set_header Accept-Encoding "";
}
