FROM {{ container_base_image }}
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*
RUN ARCH=$(dpkg --print-architecture) && \
    curl -fsSL "https://releases.mattermost.com/{{ mattermost_version }}/mattermost-{{ mattermost_version }}-linux-${ARCH}.tar.gz" \
    -o /tmp/mattermost.tar.gz && \
    tar -xzf /tmp/mattermost.tar.gz -C /opt && \
    rm /tmp/mattermost.tar.gz
RUN useradd -r -u 10001 -m mattermost && \
    mkdir -p /opt/mattermost/data /opt/mattermost/logs /opt/mattermost/config && \
    chown -R mattermost:mattermost /opt/mattermost
USER mattermost
EXPOSE {{ mattermost_port }}
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -fs http://localhost:{{ mattermost_port }}/mattermost/api/v4/system/ping || exit 1
ENTRYPOINT ["/opt/mattermost/bin/mattermost"]
