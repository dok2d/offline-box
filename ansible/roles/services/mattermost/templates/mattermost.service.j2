[Unit]
Description=Mattermost team messaging (podman)
After=default.target

[Service]
Environment="XDG_RUNTIME_DIR=/run/user/{{ svc_uid }}"
ExecStartPre=-/usr/bin/podman rm -f mattermost
ExecStart=/usr/bin/podman run \
  --name mattermost \
  --replace \
  --rm \
  --cap-drop=ALL \
  --security-opt=no-new-privileges \
  -p {{ listen_addr }}:{{ mattermost_port }}:{{ mattermost_port }} \
  --log-driver=k8s-file \
  --log-opt=path={{ container_log_dir }}/mattermost/mattermost.log \
  --env-file={{ mattermost_config_dir }}/mattermost.env \
  -v {{ mattermost_data_dir }}:/opt/mattermost/data:rw \
  -v {{ mattermost_config_dir }}:/opt/mattermost/config:rw \
  {{ mattermost_image_full }}
ExecStop=/usr/bin/podman stop mattermost
MemoryMax=1G
CPUQuota=200%
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
