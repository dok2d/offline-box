# Nextcloud file hosting
location /nextcloud/ {
    proxy_pass http://{{ listen_addr }}:{{ nextcloud_port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    include /etc/nginx/snippets/security-headers.conf;
    limit_req zone=general burst=20 nodelay;
    client_max_body_size {{ nextcloud_upload_max_size }};

    # WebSocket for Notify Push
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    # Reverse proxy awareness
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /nextcloud;

    # Disable buffering for large uploads and WebDAV
    proxy_request_buffering off;
    proxy_buffering off;

    # Timeouts for large uploads
    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
    proxy_connect_timeout 300;
}
