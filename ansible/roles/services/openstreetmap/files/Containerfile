FROM docker.io/library/debian:13-slim
RUN apt-get update && \
    apt-get install -y --no-install-recommends nodejs npm curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*
RUN npm install -g tileserver-gl-light@4 && npm cache clean --force
RUN useradd -r -u 10001 -m tileserver
USER tileserver
WORKDIR /data
EXPOSE 8002
ENTRYPOINT ["tileserver-gl-light", "--port", "8002", "--basePath", "/osm"]
