FROM {{ container_base_image }}
RUN apt-get update && \
    apt-get install -y --no-install-recommends nodejs npm curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*
{% if offline_mode | default(false) %}
COPY npm-packages/ /tmp/npm-packages/
RUN npm install -g /tmp/npm-packages/tileserver-gl-light-{{ tileserver_gl_version }}.tgz && \
    rm -rf /tmp/npm-packages && npm cache clean --force
{% else %}
RUN npm install -g tileserver-gl-light@{{ tileserver_gl_version }} && npm cache clean --force
{% endif %}
RUN useradd -r -u 10001 -m tileserver
USER tileserver
WORKDIR /data
EXPOSE {{ openstreetmap_port }}
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD curl -fs http://localhost:8002/osm/ || exit 1
ENTRYPOINT ["tileserver-gl-light", "--port", "{{ openstreetmap_port }}", "--basePath", "/osm"]
