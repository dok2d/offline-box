FROM docker.io/library/debian:13-slim AS build
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*
RUN curl -fsSL -o /usr/local/bin/vaultwarden \
    https://github.com/dani-garcia/vaultwarden/releases/latest/download/vaultwarden-linux-x86_64 && \
    chmod +x /usr/local/bin/vaultwarden
RUN mkdir -p /opt/web-vault && \
    curl -fsSL -L https://github.com/dani-garcia/bw_web_builds/releases/latest/download/bw_web_v2024.12.0.tar.gz | \
    tar xz -C /opt

FROM docker.io/library/debian:13-slim
RUN apt-get update && \
    apt-get install -y --no-install-recommends libssl3 ca-certificates && \
    rm -rf /var/lib/apt/lists/*
COPY --from=build /usr/local/bin/vaultwarden /usr/local/bin/vaultwarden
COPY --from=build /opt/web-vault /opt/web-vault
RUN useradd -r -u 10001 -m vaultwarden && \
    mkdir -p /data && chown -R vaultwarden:vaultwarden /data
USER vaultwarden
EXPOSE 8010
ENTRYPOINT ["/usr/local/bin/vaultwarden"]
