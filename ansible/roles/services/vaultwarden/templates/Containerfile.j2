FROM docker.io/vaultwarden/server:{{ vaultwarden_version }} AS source

FROM {{ container_base_image }}
RUN apt-get update && \
    apt-get install -y --no-install-recommends libssl3 ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*
COPY --from=source /vaultwarden /usr/local/bin/vaultwarden
COPY --from=source /web-vault /opt/web-vault
RUN useradd -r -u 10001 -m vaultwarden && \
    mkdir -p /data && chown -R vaultwarden:vaultwarden /data
USER vaultwarden
EXPOSE {{ vaultwarden_port }}
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD curl -fs http://localhost:8010/vaultwarden/alive || exit 1
ENTRYPOINT ["/usr/local/bin/vaultwarden"]
