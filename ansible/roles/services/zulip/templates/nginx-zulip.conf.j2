# Zulip team chat
# Note: Zulip does not support sub-path natively; absolute paths are proxied
# via additional location blocks matching Zulip's generated URLs.

location /zulip/ {
    proxy_pass http://{{ listen_addr }}:{{ zulip_port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    include /etc/nginx/snippets/security-headers.conf;
    limit_req zone=general burst=30 nodelay;
    client_max_body_size 25m;

    # WebSocket (event system)
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
}

# Zulip generates absolute paths — proxy them all to the container
location /static/ {
    proxy_pass http://{{ listen_addr }}:{{ zulip_port }}/static/;
    proxy_set_header Host $host;
    proxy_cache_valid 200 1d;
    add_header Cache-Control "public, max-age=86400";
}

location /api/ {
    proxy_pass http://{{ listen_addr }}:{{ zulip_port }}/api/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    include /etc/nginx/snippets/security-headers.conf;
    limit_req zone=general burst=20 nodelay;
    client_max_body_size 25m;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 3600s;
}

location /json/ {
    proxy_pass http://{{ listen_addr }}:{{ zulip_port }}/json/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    include /etc/nginx/snippets/security-headers.conf;
    limit_req zone=general burst=20 nodelay;
    client_max_body_size 25m;
}

location /accounts/ {
    proxy_pass http://{{ listen_addr }}:{{ zulip_port }}/accounts/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    include /etc/nginx/snippets/security-headers.conf;
    limit_req zone=general burst=10 nodelay;
}

location /user_uploads/ {
    proxy_pass http://{{ listen_addr }}:{{ zulip_port }}/user_uploads/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    include /etc/nginx/snippets/security-headers.conf;
    client_max_body_size 25m;
}
