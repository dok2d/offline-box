# Zulip configuration
# This file is deployed to {{ zulip_config_dir }}/zulip.env (mode 0640)

# External hostname (no protocol, no port, no path)
SETTING_EXTERNAL_HOST={{ server_name }}

# Disable HTTPS inside the container — nginx terminates TLS
DISABLE_HTTPS=true
SSL_CERTIFICATE_GENERATION=none

# Admin account
ZULIP_ADMINISTRATOR={{ zulip_admin_email }}

# Secret key — must be a long random string
SECRETS_secret_key={{ zulip_secret_key }}

# Email (optional — leave empty for no outbound email)
SETTING_EMAIL_HOST=
SETTING_EMAIL_HOST_USER=
SETTING_EMAIL_PORT=587
SETTING_EMAIL_USE_TLS=True
SETTING_NOREPLY_EMAIL_ADDRESS=noreply@{{ server_name }}
SECRETS_email_password=

# Proxy headers
SETTING_BEHIND_PROXY=true
